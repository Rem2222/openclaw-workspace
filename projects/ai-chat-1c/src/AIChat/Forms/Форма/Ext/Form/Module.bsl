#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Настройки по умолчанию
	Если Не ЗначениеЗаполнено(АдресAPI) Тогда
		АдресAPI = "https://api.z.ai/api/coding/paas/v4";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СистемныйПромпт) Тогда
		СистемныйПромпт = "Ты полезный ИИ-ассистент. Отвечай на русском языке.";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Модель) Тогда
		Модель = "glm-5.1";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// Заполнить список моделей
	СписокМоделей = Новый СписокЗначений;
	СписокМоделей.Добавить("glm-5.1",       "GLM-5.1 (Z.AI)");
	СписокМоделей.Добавить("glm-5",         "GLM-5 (Z.AI)");
	СписокМоделей.Добавить("glm-5-turbo",   "GLM-5-Turbo (Z.AI)");
	СписокМоделей.Добавить("glm-4.7",       "GLM-4.7 (Z.AI)");
	СписокМоделей.Добавить("glm-4.7-flash", "GLM-4.7 Flash (Z.AI)");
	СписокМоделей.Добавить("glm-4.6",       "GLM-4.6 (Z.AI)");
	СписокМоделей.Добавить("glm-4.5",       "GLM-4.5 (Z.AI)");
	СписокМоделей.Добавить("glm-4.5-air",   "GLM-4.5 Air (Z.AI)");
	СписокМоделей.Добавить("minimax-m2.7",  "MiniMax M2.7");
	СписокМоделей.Добавить("deepseek-chat", "DeepSeek Chat");
	СписокМоделей.Добавить("gemini-2.0-flash", "Gemini 2.0 Flash");
	Элементы.Модель.СписокВыбора = СписокМоделей;
	
	// Восстановить сообщения из JSON
	СообщенияМассив = Новый Массив;
	Если ЗначениеЗаполнено(СообщенияJSON) Тогда
		Попытка
			Чтение = Новый ЧтениеJSON;
			Чтение.УстановитьСтроку(СообщенияJSON);
			СообщенияМассив = ПрочитатьJSON(Чтение);
			Чтение.Закрыть();
		Исключение
			СообщенияМассив = Новый Массив;
		КонецПопытки;
	КонецЕсли;
	
	Если СообщенияМассив.Количество() = 0 Тогда
		СообщенияМассив.Добавить(Новый Структура("role,content", "system", СистемныйПромпт));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура МодельПриИзменении(Элемент)
	// Автоподстановка URL при выборе модели
	Если СтрНайти(Модель, "glm-") > 0 Тогда
		АдресAPI = "https://api.z.ai/api/coding/paas/v4";
	ИначеЕсли СтрНайти(Модель, "minimax") > 0 Тогда
		АдресAPI = "https://api.minimax.chat/v1";
	ИначеЕсли СтрНайти(Модель, "gemini") > 0 Тогда
		АдресAPI = "https://generativelanguage.googleapis.com/v1beta/openai";
	ИначеЕсли СтрНайти(Модель, "deepseek") > 0 Тогда
		АдресAPI = "https://api.deepseek.com";
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СистемныйПромптПриИзменении(Элемент)
	Если СообщенияМассив.Количество() > 0 
		И СообщенияМассив[0].Свойство("role") 
		И СообщенияМассив[0].role = "system" Тогда
		СообщенияМассив[0].content = СистемныйПромпт;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОтправитьОбработка(Команда)
	
	Если Не ЗначениеЗаполнено(Сообщение) Тогда
		ПоказатьПредупреждение(, "Введите сообщение");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КлючAPI) Тогда
		ПоказатьПредупреждение(, "Укажите API ключ в настройках");
		Возврат;
	КонецЕсли;
	
	ТекстПользователя = СокрЛП(Сообщение);
	
	// Добавить сообщение пользователя в массив
	СообщенияМассив.Добавить(Новый Структура("role,content", "user", ТекстПользователя));
	
	// Обновить отображение
	ИсторияЧата = ИсторияЧата 
		+ ?(ЗначениеЗаполнено(ИсторияЧата), Символы.ПС + Символы.ПС, "")
		+ "🧑 Вы:" + Символы.ПС + ТекстПользователя;
	Сообщение = "";
	
	// Блокируем ввод
	Элементы.Сообщение.Доступность = Ложь;
	ЭтаФорма.ОбновитьОтображениеДанных();
	Состояние("AI думает...");
	
	// Вызываем API
	Попытка
		ОтветИИ = ОтправитьЗапросAPI();
		
		Если ЗначениеЗаполнено(ОтветИИ) Тогда
			СообщенияМассив.Добавить(Новый Структура("role,content", "assistant", ОтветИИ));
			ИсторияЧата = ИсторияЧата 
				+ Символы.ПС + Символы.ПС 
				+ "🤖 AI:" + Символы.ПС + ОтветИИ;
		КонецЕсли;
		
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ИсторияЧата = ИсторияЧата 
			+ Символы.ПС + Символы.ПС 
			+ "❌ Ошибка: " + ТекстОшибки;
		// Убираем сообщение пользователя из массива при ошибке
		Если СообщенияМассив.Количество() > 0 Тогда
			Последний = СообщенияМассив[СообщенияМассив.Количество() - 1];
			Если Последний.role = "user" И Последний.content = ТекстПользователя Тогда
				СообщенияМассив.Удалить(СообщенияМассив.Количество() - 1);
			КонецЕсли;
		КонецЕсли;
	КонецПопытки;
	
	// Разблокируем ввод
	Элементы.Сообщение.Доступность = Истина;
	Состояние("");
	ЭтаФорма.ОбновитьОтображениеДанных();
	
	// Сохраняем историю
	СохранитьСообщения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОбработка(Команда)
	ИсторияЧата = "";
	СообщенияМассив = Новый Массив;
	СообщенияМассив.Добавить(Новый Структура("role,content", "system", СистемныйПромпт));
	СообщенияJSON = "";
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СохранитьСообщения()
	Попытка
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(, Символы.Таб));
		ЗаписатьJSON(Запись, СообщенияМассив);
		СообщенияJSON = Запись.Закрыть();
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция ОтправитьЗапросAPI()
	
	// Формируем JSON body
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(, Символы.Таб));
	
	Запись.ЗаписатьНачалоОбъекта();
	Запись.ЗаписатьИмяСвойства("model");
	Запись.ЗаписатьЗначение(Модель);
	Запись.ЗаписатьИмяСвойства("messages");
	ЗаписатьJSON(Запись, СообщенияМассив);
	Запись.ЗаписатьИмяСвойства("stream");
	Запись.ЗаписатьЗначение(Ложь);
	Запись.ЗаписатьКонецОбъекта();
	
	ТелоJSON = Запись.Закрыть();
	
	// Разбираем URL на хост и путь
	Адрес = СокрЛП(АдресAPI);
	Если СтрЗаканчиваетсяНа(Адрес, "/") Тогда
		Адрес = Лев(Адрес, СтрДлина(Адрес) - 1);
	КонецЕсли;
	
	ПолныйПуть = "/chat/completions";
	Хост = Адрес;
	Порт = 443;
	ИспользоватьHTTPS = Истина;
	
	ПозицияПротокола = СтрНайти(Адрес, "://");
	Если ПозицияПротокола > 0 Тогда
		ИспользоватьHTTPS = (Сред(Адрес, ПозицияПротокола + 1, 4) = "https");
		Хвост = Сред(Адрес, ПозицияПротокола + 3);
		ПозицияСлеша = СтрНайти(Хвост, "/");
		Если ПозицияСлеша > 0 Тогда
			Хост = Лев(Хвост, ПозицияСлеша - 1);
			ПолныйПуть = Сред(Хвост, ПозицияСлеша) + ПолныйПуть;
		Иначе
			Хост = Хвост;
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем порт в хосте
	ПозицияПорта = СтрНайти(Хост, ":");
	Если ПозицияПорта > 0 Тогда
		Порт = Число(Сред(Хост, ПозицияПорта + 1));
		Хост = Лев(Хост, ПозицияПорта - 1);
	Иначе
		Порт = ?(ИспользоватьHTTPS, 443, 80);
	КонецЕсли;
	
	// Создаём HTTP соединение
	Если ИспользоватьHTTPS Тогда
		Соединение = Новый HTTPСоединение(Хост, Порт, , , , , 
			Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено));
	Иначе
		Соединение = Новый HTTPСоединение(Хост, Порт);
	КонецЕсли;
	
	// Заголовки
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Authorization", "Bearer " + КлючAPI);
	
	// Запрос
	Запрос = Новый HTTPЗапрос(ПолныйПуть, Заголовки);
	Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);
	
	// Отправка
	ОтветHTTP = Соединение.ОтправитьДляОбработки(Запрос);
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТелоОшибки = ОтветHTTP.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		ВызватьИсключение("HTTP " + ОтветHTTP.КодСостояния + ": " + ТелоОшибки);
	КонецЕсли;
	
	// Парсим ответ
	ТекстОтвета = ОтветHTTP.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ТекстОтвета);
	ОтветСтруктура = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	
	Если ТипЗнч(ОтветСтруктура) = Тип("Структура") 
		И ОтветСтруктура.Свойство("choices") 
		И ОтветСтруктура.choices.Количество() > 0 Тогда
		
		ПервыйChoice = ОтветСтруктура.choices[0];
		Если ПервыйChoice.Свойство("message") И ПервыйChoice.message.Свойство("content") Тогда
			Возврат ПервыйChoice.message.content;
		КонецЕсли;
	КонецЕсли;
	
	ВызватьИсключение("Не удалось разобрать ответ API");
	
КонецФункции

#КонецОбласти
