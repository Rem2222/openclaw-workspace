FROM python:3.13-slim

WORKDIR /app

# Установить зависимости
RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

# Установить memU
RUN pip install --no-cache-dir memu-py

# Копировать тестовый скрипт
COPY test_memu_docker.py .

# Запустить
CMD ["python", "test_memu_docker.py"]
